# 1. 读取Verilog文件
read_verilog -sv fma.sv splitf.sv add_compressor.sv find_first1.sv
# 2. 综合为门级电路（针对通用工艺库，无工艺库也可生成抽象门级网表）
proc
flatten     # 拍扁层级，方便全局优化
alumacc     # 提取算术单元
techmap     # 通用映射
opt
synth -top fma
# 3. 输出门级网表（JSON格式，易解析）
write_json test_netlist.json
# 4. （可选）直接打印电路统计信息（包含门数量、层级）
stat

ltp
